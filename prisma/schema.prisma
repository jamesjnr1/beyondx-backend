generator client {
  provider        = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}

model Worker {
  id             String       @id @default(uuid())
  workerId       String       @unique
  fullName       String
  pinHash        String
  phone          String?
  prisonFacility String?
  releaseDate    DateTime?
  offenseLevel   OffenseLevel @default(none)
  offenseNotes   String?
  skills         String[]
  bio            String?
  dailyCharge    Decimal      @default(80)
  rating         Decimal      @default(0)
  tasksCompleted Int          @default(0)
  totalEarned    Decimal      @default(0)
  isActive       Boolean      @default(true)
  gpsVerified    Boolean      @default(false)
  createdAt      DateTime     @default(now())
  dispatches     Dispatch[]
  ussdSessions   UssdSession[]
  tasks Task[]
}

model Employer {
  id            String     @id @default(uuid())
  email         String     @unique
  passwordHash  String
  orgName       String
  contactPerson String?
  phone         String?
  address       String?
  region        String?
  isVerified    Boolean    @default(false)
  acknowledgedAt DateTime?
  createdAt     DateTime   @default(now())
  dispatches    Dispatch[]
  payments      Payment[]
  tasks      Task[]
}

model Dispatch {
  id              String         @id @default(uuid())
  reference       String         @unique
  worker          Worker         @relation(fields: [workerId], references: [id])
  workerId        String
  employer        Employer       @relation(fields: [employerId], references: [id])
  employerId      String
  taskType        String
  taskDescription String?
  location        String?
  startDate       DateTime
  durationDays    Decimal
  workerRate      Decimal
  platformFee     Decimal
  totalAmount     Decimal
  status          DispatchStatus @default(pending_payment)
  payment         Payment?
  createdAt       DateTime       @default(now())
}

model Payment {
  id          String    @id @default(uuid())
  paystackRef String    @unique
  employer    Employer  @relation(fields: [employerId], references: [id])
  employerId  String
  dispatch    Dispatch  @relation(fields: [dispatchId], references: [id])
  dispatchId  String    @unique
  amount      Decimal
  currency    String    @default("GHS")
  method      PayMethod
  status      PayStatus @default(pending)
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
}

model UssdSession {
  sessionId String   @id
  msisdn    String
  worker    Worker?  @relation(fields: [workerId], references: [id])
  workerId  String?
  step      String   @default("main")
  data      Json     @default("{}")
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Task {
  id          String     @id @default(uuid())
  employer    Employer   @relation(fields: [employerId], references: [id])
  employerId  String
  taskType    String
  description String?
  location    String
  duration    String
  pay         Decimal
  status      TaskStatus @default(open)
  createdAt   DateTime   @default(now())
  acceptedBy   Worker?  @relation(fields: [workerId], references: [id])
workerId     String?
}

enum TaskStatus {
  open
  accepted
  pending_confirmation
  completed
  cancelled
}

enum OffenseLevel {
  none
  minor
  major
}

enum DispatchStatus {
  pending_payment
  confirmed
  active
  completed
  cancelled
}

enum PayMethod {
  mtn_momo
  voda_cash
  airteltigo
  bank_card
}

enum PayStatus {
  pending
  success
  failed
  reversed
}